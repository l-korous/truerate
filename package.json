{
  "name": "truerate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "dev:api": "pnpm --filter @truerate/api dev",
    "dev:mcp": "pnpm --filter @truerate/mcp dev",
    "dev:web": "pnpm --filter @truerate/web dev",
    "dev:ext": "pnpm --filter @truerate/extension dev",
    "test": "pnpm --filter @truerate/core build && pnpm --filter @truerate/harness build && pnpm -r --workspace-concurrency=1 test",
    "test:e2e": "pnpm --filter @truerate/web test:e2e"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}

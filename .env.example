# ─── Shared ───────────────────────────────────────────────────────────────
# JWT signing secret (issued by the API, verified by API + MCP).
# In production this is injected from Azure Key Vault, NOT committed.
TRUERATE_JWT_SECRET=dev-only-change-me-to-a-32-byte-random-string

# AES-256-GCM key for encrypting membership credentials at rest.
# Format: <version-id>:<base64-32-bytes>  e.g. "mykey-v1:BASE64..."
# Generate with:
#   node -e "console.log('mykey-v1:' + require('crypto').randomBytes(32).toString('base64'))"
# Bare base64 (no version-id prefix) is also accepted for legacy compatibility.
# In production this lives in Key Vault and is referenced via managed identity.
TRUERATE_CRED_KEY=

# Previous AES-256 key kept during key rotation (same format as TRUERATE_CRED_KEY).
# Set this when rotating to a new key so existing blobs (encrypted with the old key)
# can still be decrypted. Run the re-encryption job to migrate all blobs, then
# remove this var on the next deploy.
# TRUERATE_CRED_KEY_PREV=

# ─── Cosmos DB (managed, serverless) ────────────────────────────────────────
# Using the connection string is fine for local dev. In Azure, prefer
# AAD / managed identity (see infra/README) and drop the key entirely.
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=truerate
# Set to "true" to run fully in-memory with no Cosmos account (local demos).
TRUERATE_INMEMORY=true

# ─── Providers ──────────────────────────────────────────────────────────────
# Booking.com Demand API credentials. When absent, the Booking adapter runs
# in MOCK mode and returns deterministic, realistic anonymous-vs-member rates
# so the whole product is demoable without partner access.
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=
BOOKING_API_BASE=https://demandapi.booking.com/3.1

# ─── Service URLs ───────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8787
API_PORT=8787
MCP_PORT=8788

# Web app (Next.js) — public vars must be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
